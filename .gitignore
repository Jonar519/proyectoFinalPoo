# =========================
# AIRCONTROL PRO - .gitignore
# =========================

# --- Secrets / local env files ---
.env
.env.*
!.env.example
backend/.env
backend/.env.*
!backend/.env.example
!backend/.env.render.example

# --- Java / Maven / Spring ---
**/target/
**/*.class
**/*.log
**/.spring-boot-devtools.properties

# --- Node / Angular ---
**/node_modules/
frontend/dist/
**/.angular/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/pnpm-debug.log*

# --- OS files ---
Thumbs.db
Desktop.ini
.DS_Store

# --- IDE / editor ---
.vscode/
.idea/
*.iml
*.ipr
*.iws

# --- Cursor / tooling ---
.cursor/

# --- Coverage / test artifacts ---
coverage/

